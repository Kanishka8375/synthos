# ─── Supabase (free at supabase.com) ──────────────────────────────────────────
# 1. Go to https://supabase.com and create a free project
# 2. Settings → API → copy Project URL and anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY

# For DB migrations (optional — only needed to run scripts/migrate.mjs or /api/setup)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ─── Hugging Face (free at huggingface.co) ────────────────────────────────────
# 1. Go to https://huggingface.co/settings/tokens
# 2. Create a new token (read access is enough)
HUGGINGFACE_TOKEN=hf_YOUR_TOKEN_HERE

# ─── Pollinations.ai ──────────────────────────────────────────────────────────
# No API key needed — image generation is completely free, no account required!
